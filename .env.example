# ─── Copie este arquivo para .env e preencha com suas chaves ───────────────
# cp .env.example .env

# ── OBRIGATÓRIO ─────────────────────────────────────────────────────────────
# Chave da API da Anthropic (usada pelo processor e pelos geradores de conteúdo)
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sua_chave_aqui

# ── OPCIONAL — GitHub (aumenta rate limit de 60 para 5000 requests/hora) ───
# Obter em: https://github.com/settings/tokens (token clássico, sem escopes)
GITHUB_TOKEN=

# ── OPCIONAL — WordPress (para publicação automática futura) ────────────────
WORDPRESS_URL=https://seublog.com
WORDPRESS_USER=seu_usuario
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── OPCIONAL — Higgsfield AI (geração de imagens e vídeos) ──────────────────
# Obter em: https://higgsfield.ai
HIGGSFIELD_API_KEY=
